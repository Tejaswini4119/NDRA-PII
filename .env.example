# NDRA runtime mode
ENV=dev

# API runtime paths
UPLOAD_DIR=./uploads
ARTIFACTS_DIR=./artifacts

# Optional audit file override (used in container)
AUDIT_LOG_FILE=./audit/audit.log

# Optional integration keys
OPENAI_API_KEY=
GEMINI_API_KEY=

# Security / API hardening
# List fields must be set as JSON arrays in environment variables.
# Comma-separated strings are NOT supported by pydantic-settings for List fields.
CORS_ORIGINS=["http://localhost:3000"]

# Maximum file upload size in bytes (default 50 MB = 52428800).
MAX_UPLOAD_BYTES=52428800

# List of absolute directory prefixes allowed for /analyze/path.
# Leave empty (default) to disable the endpoint entirely in production.
ALLOWED_PATH_PREFIXES=[]

# Grafana admin password — override this before deploying.
GF_SECURITY_ADMIN_PASSWORD=changeme
